   "metadata": {},
   "source": [
    "## 4. Train Patch — YOLO26n (1000 epochs)\n",
    "\n",
    "YOLO26 is NMS-free (end-to-end detection). If the model name is not yet in\n",
    "the Ultralytics registry, update it below once you confirm the official name."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "check-yolo26",
   "metadata": {},
   "outputs": [],
   "source": [
    "# First confirm YOLO26 model name in the current Ultralytics version\n",
    "from ultralytics import YOLO\n",
    "import ultralytics\n",
    "print('Ultralytics version:', ultralytics.__version__)\n",
    "# Attempt load — update the name if this fails\n",
    "try:\n",
    "    m = YOLO('yolo26n.pt')\n",
    "    print('yolo26n loaded OK')\n",
    "except Exception as e:\n",
    "    print('Error:', e)\n",
    "    print('Check https://docs.ultralytics.com/models/yolo26/ for the correct model name')"
   ]
  },
