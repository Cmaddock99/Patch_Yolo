   "source": [
    "## 2. Train Patch — YOLOv8n (1000 epochs)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "train-yolov8",
   "metadata": {},
   "outputs": [],
   "source": [
    "!python experiments/ultralytics_patch.py \\\n",
    "    --model yolov8n \\\n",
    "    --epochs 1000 \\\n",
    "    --lr 0.01 \\\n",
    "    --tv-weight 0.05 \\\n",
    "    --patch-size 100 \\\n",
    "    --batch-size 8 \\\n",
    "    --display 5"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
