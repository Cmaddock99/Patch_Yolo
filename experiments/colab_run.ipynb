   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "show-yolov8-results",
   "metadata": {},
   "outputs": [],
   "source": [
    "# View clean vs patched comparison (first 3 images)\n",
    "import os\n",
    "from IPython.display import Image as IPImage, display\n",
    "\n",
    "orig_dir = 'outputs/yolov8n_patch_v1/original'\n",
    "patch_dir = 'outputs/yolov8n_patch_v1/patched'\n",
    "\n",
    "for orig, patched in zip(\n",
    "    sorted(os.listdir(orig_dir))[:3],\n",
    "    sorted(os.listdir(patch_dir))[:3]\n",
    "):\n",
    "    print('CLEAN:', orig)\n",
    "    display(IPImage(f'{orig_dir}/{orig}', width=400))\n",
    "    print('PATCHED:', patched)\n",
    "    display(IPImage(f'{patch_dir}/{patched}', width=400))"
   ]
  },
